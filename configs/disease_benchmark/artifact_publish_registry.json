{
  "default_asset_group": "all",
  "asset_groups": {
    "comparison-model-family": [
      "bioreason-pro-rl-paper"
    ],
    "all": [
      "bioreason-pro-rl-paper"
    ]
  },
  "assets": {
    "bioreason-pro-rl-paper": {
      "display_name": "bioreason-pro-rl-paper",
      "artifact_name": "bioreason-pro-rl",
      "artifact_type": "model",
      "registry_env_var": "BIOREASON_RL_PAPER_MODEL_REGISTRY_PATH",
      "artifact_aliases": [
        "production",
        "{benchmark_alias}"
      ],
      "sources": [
        {
          "type": "local_dir",
          "local_dir": "${BIOREASON_RL_PAPER_MODEL_SOURCE_DIR}",
          "required_paths": [
            "config.json"
          ]
        },
        {
          "type": "huggingface",
          "repo_id_env": "BIOREASON_PRO_RL_HF_REPO",
          "local_dir": "data/artifacts/models/bioreason_pro_rl_paper",
          "required_paths": [
            "config.json"
          ]
        }
      ]
    }
  }
}
