# Local source directories for prediction baselines.
# These are prediction files, not model checkpoints.
export BIOREASON_BLAST_DIAMOND_PREDICTIONS_DIR=""
export BIOREASON_ESM_STANDALONE_PREDICTIONS_DIR=""

# Local source directories for model checkpoints, if you already have them
export BIOREASON_BASE_MODEL_SOURCE_DIR=""
export BIOREASON_SFT_MODEL_SOURCE_DIR=""
export BIOREASON_RL_MODEL_SOURCE_DIR=""

# Optional Hugging Face sources for public checkpoints.
# BioReason-Pro base does not currently have a public HF repo configured here.
export BIOREASON_PRO_BASE_HF_REPO=""
export BIOREASON_PRO_SFT_HF_REPO="wanglab/bioreason-pro-sft"
export BIOREASON_PRO_RL_HF_REPO="wanglab/bioreason-pro-rl"
